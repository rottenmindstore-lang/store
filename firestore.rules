rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dados públicos da loja — leitura pública, escrita só autenticado
    match /siteData/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Analytics — escrita pública (visitantes), leitura só autenticado
    match /analytics_pageviews/{doc} {
      allow create: if true;
      allow read: if request.auth != null;
    }
    match /analytics_clicks/{doc} {
      allow create: if true;
      allow read: if request.auth != null;
    }
  }
}
